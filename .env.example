# OpsPilot AI – Environment Variables
# Copy this file to .env and fill in your values.
# Vite exposes only VITE_* variables to the browser.

# IBM Cloud API key — used to obtain an IAM Bearer token via:
#   POST https://iam.cloud.ibm.com/identity/token
VITE_WATSONX_API_KEY=your-ibm-cloud-api-key-here

# watsonx.ai deployment endpoint (from IBM WML sample code)
VITE_WATSONX_ENDPOINT=https://us-south.ml.cloud.ibm.com/ml/v4/deployments/<deployment-id>/ai_service?version=2021-05-01
